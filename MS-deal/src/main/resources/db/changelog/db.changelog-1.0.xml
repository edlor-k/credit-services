<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="1" author="edlor-k">
        <createTable tableName="passport">
            <column name="passport_uuid" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="series" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            <column name="number" type="VARCHAR(6)">
                <constraints nullable="false"/>
            </column>
            <column name="issue_branch" type="VARCHAR(100)"/>
            <column name="issue_date" type="DATE"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="edlor-k">
        <addUniqueConstraint tableName="passport" columnNames="series, number" constraintName="uc_passport_series_number"/>
    </changeSet>

    <changeSet id="3" author="edlor-k">
        <createTable tableName="client">
            <column name="client_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="VARCHAR(30)"/>
            <column name="birth_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="gender" type="VARCHAR(20)"/>
            <column name="marital_status" type="VARCHAR(20)"/>
            <column name="dependent_amount" type="INT"/>
            <column name="passport_id" type="UUID">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="employment_id" type="JSONB"/>
            <column name="account_number" type="VARCHAR(30)">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="edlor-k">
        <addForeignKeyConstraint
                baseTableName="client"
                baseColumnNames="passport_id"
                constraintName="fk_client_passport"
                referencedTableName="passport"
                referencedColumnNames="passport_uuid"/>
    </changeSet>

    <changeSet id="5" author="edlor-k">
        <createTable tableName="credit">
            <column name="credit_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="term" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="monthly_payment" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="rate" type="DECIMAL(5,2)"/>
            <column name="psk" type="DECIMAL(5,2)"/>
            <column name="payment_schedule" type="JSONB"/>
            <column name="insurance_enabled" type="BOOLEAN"/>
            <column name="salary_client" type="BOOLEAN"/>
            <column name="credit_status" type="VARCHAR(20)"/>
        </createTable>
    </changeSet>

    <changeSet id="6" author="edlor-k">
        <createTable tableName="statement">
            <column name="statement_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="credit_id" type="UUID"/>
            <column name="status" type="VARCHAR(30)"/>
            <column name="creation_date" type="TIMESTAMP"/>
            <column name="applied_offer" type="JSONB"/>
            <column name="sign_date" type="TIMESTAMP"/>
            <column name="ses_code" type="VARCHAR(255)"/>
            <column name="status_history" type="JSONB"/>
        </createTable>
    </changeSet>

    <changeSet id="7" author="edlor-k">
        <addForeignKeyConstraint
                baseTableName="statement"
                baseColumnNames="client_id"
                constraintName="fk_statement_client"
                referencedTableName="client"
                referencedColumnNames="client_id"/>
    </changeSet>

    <changeSet id="8" author="edlor-k">
        <addForeignKeyConstraint
                baseTableName="statement"
                baseColumnNames="credit_id"
                constraintName="fk_statement_credit"
                referencedTableName="credit"
                referencedColumnNames="credit_id"/>
    </changeSet>

</databaseChangeLog>
